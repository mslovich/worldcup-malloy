  query: top_women_scorers is goals -> top_scorers + { where: tournament.gender = 'Women' }
  query: goals_by_minute is goals -> goals_by_minute

  // Matches ─────────────────────────────────────────────────────────────────────
  query: goals_per_match_by_tournament is matches -> by_tournament
  query: highest_scoring_matches is matches -> highest_scoring
  query: match_dashboard_example is matches -> match_dashboard + { where: match_id = 'M-2019-12' }

