  // People: managers, referees, players ─────────────────────────────────────────
  query: top_attacking_managers is manager_appearances -> top_attacking_managers
  query: strictest_referees is referee_appearances -> strictest_referees
  //" Discipline ∩ scoring: of players sent off, how many scored in that match?
  query: sent_off_who_scored is bookings -> {
